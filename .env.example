# ============================================
# SERVER ENVIRONMENT VARIABLES
# ============================================
# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_ordering

# Required: 64+ character random string for JWT signing
JWT_SECRET=your-secret-key-change-in-production

# Server port (default: 3001)
PORT=3001

# Set to "production" on Railway/Render
NODE_ENV=development

# Required: Frontend origin for CORS + cookies
FRONTEND_URL=http://localhost:5173

# ============================================
# CLIENT ENVIRONMENT VARIABLES (prefix with VITE_)
# Set these in Vercel dashboard, NOT in .env files
# ============================================
# VITE_API_URL=https://your-app.railway.app
# VITE_SOCKET_URL=https://your-app.railway.app
