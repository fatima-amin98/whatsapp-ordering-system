# Production backend URL (Railway/Render)
# Example: https://your-app.railway.app
# When unset, uses '/api' (works with Vite dev proxy)
VITE_API_URL=

# Production WebSocket URL (Railway/Render)
# Defaults to VITE_API_URL if unset
# When both unset, connects to same origin (works with Vite dev proxy)
VITE_SOCKET_URL=
