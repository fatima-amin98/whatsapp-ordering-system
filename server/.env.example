# Required: PostgreSQL connection string
# For Railway: Use the connection string from Railway dashboard
# For Render: Use the Internal Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_ordering

# Required: 64+ character random string for JWT signing
JWT_SECRET=your-256-bit-secret-change-in-production

# Server port (default: 3001). Railway/Render set this via PORT env var.
PORT=3001

# Must be "production" on Railway/Render
NODE_ENV=development

# Required: Frontend origin for CORS + cookie domain
# Local: http://localhost:5173
# Production: https://your-store.vercel.app
FRONTEND_URL=http://localhost:5173

# Optional: Supabase Storage for product image uploads
# Create a project at https://supabase.com, then create a public bucket named "product-images"
# SUPABASE_URL=https://qtohejhrs...
# SUPABASE_SERVICE_ROLE_KEY=ey....

